# VITE_API_URL — Base URL for the backend API.
# Required for production builds (e.g. CDN / static hosting where the Vite
# dev-server proxy is not available).  Set this in your Railway / hosting
# environment before building.
#
# Example (production Railway deployment):
# VITE_API_URL=https://ai-chatbot-backend-production-d810.up.railway.app/api
#
# Leave unset in local development — Vite proxy forwards /api to localhost:8080
VITE_API_URL=https://ai-chatbot-backend-production-d810.up.railway.app/api
